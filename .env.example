# ============================================================
# ANTIGRAVITY v2.0 — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to git
# ============================================================

# App
ENVIRONMENT=development
SECRET_KEY=change_me_to_64_char_random_hex_string_here_never_use_this_default
LOG_LEVEL=INFO

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/antigravity_dev?retryWrites=true&w=majority
# Local dev: mongodb://localhost:27017/?replicaSet=rs0

# Firebase Backend (service account JSON as single-line string)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"","private_key_id":"","private_key":"","client_email":"","client_id":"","auth_uri":"","token_uri":"","auth_provider_x509_cert_url":"","client_x509_cert_url":""}

# Firebase Frontend (all NEXT_PUBLIC_ prefix for Next.js)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Anthropic (Claude claude-sonnet-4-20250514)
ANTHROPIC_API_KEY=sk-ant-api03-change-me

# Kafka (Confluent Cloud — or local docker)
KAFKA_BOOTSTRAP_SERVERS=pkc-xxxx.us-east-1.aws.confluent.cloud:9092
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SECURITY_PROTOCOL=SASL_SSL
# Local dev: localhost:29092, leave SASL fields empty

# Redis (Upstash India region — or local docker)
REDIS_URL=rediss://:password@region.upstash.io:6379
# Local dev: redis://localhost:6379

# Qdrant (self-hosted Docker)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=antigravity

# Temporal
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=antigravity

# Encryption (AES-256-GCM master key — 32 random bytes hex-encoded)
AES_MASTER_KEY=change_me_to_32_char_random_hex_string_never_use_default

# Notifications — SendGrid
SENDGRID_API_KEY=SG.change-me
SENDGRID_FROM_EMAIL=noreply@antigravity.ai
SENDGRID_FROM_NAME=AntiGravity

# Notifications — Slack
SLACK_BOT_TOKEN=xoxb-change-me
SLACK_SIGNING_SECRET=change-me

# Notifications — Twilio (International)
TWILIO_ACCOUNT_SID=ACchange-me
TWILIO_AUTH_TOKEN=change-me
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# Notifications — MSG91 (India SMS / OTP)
MSG91_AUTH_KEY=change-me
MSG91_SENDER_ID=ANTGRV
MSG91_TEMPLATE_ID=change-me

# Connector OAuth — Salesforce
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=https://yourdomain.my.salesforce.com

# Connector — Jira / Atlassian
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_USER_EMAIL=
JIRA_API_TOKEN=

# Connector — HubSpot
HUBSPOT_ACCESS_TOKEN=

# Connector — Workday
WORKDAY_CLIENT_ID=
WORKDAY_CLIENT_SECRET=
WORKDAY_TENANT_NAME=

# Connector — ServiceNow
SERVICENOW_INSTANCE=https://yourinstance.service-now.com
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=

# Connector — DocuSign
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi

# Connector — Stripe
STRIPE_SECRET_KEY=sk_test_change-me
STRIPE_WEBHOOK_SECRET=whsec_change-me

# Connector — Adyen
ADYEN_API_KEY=
ADYEN_MERCHANT_ACCOUNT=
ADYEN_ENVIRONMENT=test

# Connector — OpenExchangeRates
OPEN_EXCHANGE_RATES_APP_ID=change-me

# Connector — Zoom
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Connector — Microsoft Teams / Graph API
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Connector — Google Workspace
GOOGLE_SERVICE_ACCOUNT_JSON=

# API Base URL (for frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
